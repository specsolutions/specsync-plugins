{
  "$schema": "https://schemas.specsolutions.eu/specsync4azuredevops-config-v5-latest.json",
  "compatibilityVersion": "5",
  "configurationKey": "only-publish-test-results-plugin-sample",
  "toolSettings": {
    "disablePluginCache": true, // this is needed for plugin development only, otherwise you would need to change the package version each time.
    "plugins": [
      {
        "packageId": "SpecSync.Plugin.OnlyPublishTestResults",
        "packageVersion": "5.0.0-local",
        "packageSource": "..\\SpecSync.Plugin.OnlyPublishTestResults\\bin\\Debug",
        "parameters": {
          "TestCaseIdPropertyName": "TestCaseId"
        }
      },
      {
        "packageId": "SpecSync.Plugin.ExcelTestResults",
        "packageVersion": "5.0.0-local",
        "packageSource": "..\\..\\excel-test-results-plugin\\SpecSync.Plugin.ExcelTestResults\\bin\\Debug",
        "parameters": {
          "TestCaseIdColumnName": "TestCaseId"
        }
      }
    ]
  },
  "remote": {
    "projectUrl": "https://dev.azure.com/specsync-demo/specsync-plugins-demo",
    "scope": {
      "type": "tag"
    }
  },
  "hierarchies": [
    {
      "name": "ExcelTestResults",
      "type": "single",
      "node": {
        "testPlan": "ExcelTestResultsSample",
        "path": "ExcelTestResults"
      }
    }
  ]
}